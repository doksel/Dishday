{
  "name": "dishday",
  "version": "0.1.0",
  "private": true,
  "description": "Dishday — AI-powered meal planning platform (web · mobile · admin)",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "db:generate": "npm run db:generate -w @dishday/api",
    "db:migrate": "npm run db:migrate -w @dishday/api",
    "db:push": "npm run db:push -w @dishday/api",
    "db:seed": "npm run db:seed -w @dishday/api",
    "db:studio": "npm run db:studio -w @dishday/api"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
