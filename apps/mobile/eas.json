{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "env": {
        "EXPO_PUBLIC_API_URL": "http://localhost:4000/v1"
      },
      "ios": { "simulator": true },
      "android": { "buildType": "apk" }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://dishday-api-staging.up.railway.app/v1",
        "EXPO_PUBLIC_SUPABASE_URL": "https://YOUR-STAGING-PROJECT.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "PUT_STAGING_ANON_KEY_HERE"
      },
      "ios": { "simulator": false },
      "android": { "buildType": "apk" }
    },
    "production": {
      "distribution": "store",
      "channel": "production",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://dishday-api.up.railway.app/v1",
        "EXPO_PUBLIC_SUPABASE_URL": "https://YOUR-PROD-PROJECT.supabase.co",
        "EXPO_PUBLIC_SUPABASE_ANON_KEY": "PUT_PROD_ANON_KEY_HERE"
      },
      "autoIncrement": true
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "YOUR_APPLE_ID@example.com",
        "ascAppId": "PUT_APP_STORE_CONNECT_APP_ID_HERE",
        "appleTeamId": "PUT_APPLE_TEAM_ID_HERE"
      },
      "android": {
        "serviceAccountKeyPath": "./play-store-key.json",
        "track": "internal"
      }
    }
  }
}
