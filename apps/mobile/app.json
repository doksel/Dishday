{
  "expo": {
    "name": "Dishday",
    "slug": "dishday",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "dishday",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "icon": "./assets/icon.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.dishday.mobile"
    },
    "android": {
      "package": "app.dishday.mobile",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#006c48"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Dishday to access the camera to scan barcodes."
        }
      ],
      "expo-font",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#fcf8fb",
          "dark": {
            "image": "./assets/splash-icon.png",
            "imageWidth": 200,
            "resizeMode": "contain",
            "backgroundColor": "#101412"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
