      es: 'Frutos secos, fruta deshidratada y chips de chocolate negro.',
      fr: 'Noix, fruits secs et pépites de chocolat noir.',
    },
    imageUrl: img('photo-1599909533321-2d1d2dfdc1d4'),
    prepTimeMin: 2, cookTimeMin: 0, servings: 1,
    caloriesPerServing: 250, proteinG: 7, carbsG: 22, fatG: 16,
    tags: ['vegetarian', 'no-cook', 'energy'],
    cuisine: 'international',
    mealType: ['snack'],
    ingredients: [
      { name: 'Mixed nuts', nameI18n: { ru: 'Орехи ассорти', uk: 'Горіхи асорті', de: 'Nussmischung', it: 'Misto di noci', es: 'Frutos secos variados', fr: 'Mélange de noix' }, quantity: 30, unit: 'g', orderIndex: 0 },
      { name: 'Raisins', nameI18n: { ru: 'Изюм', uk: 'Родзинки', de: 'Rosinen', it: 'Uvetta', es: 'Pasas', fr: 'Raisins secs' }, quantity: 15, unit: 'g', orderIndex: 1 },
      { name: 'Dark chocolate chips', nameI18n: { ru: 'Капли тёмного шоколада', uk: 'Краплі темного шоколаду', de: 'Zartbitter-Schokotröpfchen', it: 'Gocce di cioccolato fondente', es: 'Chips de chocolate negro', fr: 'Pépites de chocolat noir' }, quantity: 10, unit: 'g', orderIndex: 2 },
    ],
  },
];

async function main() {
  let created = 0;
  let updated = 0;

  for (const recipe of RECIPES) {
    const { ingredients, ...rest } = recipe;
    const existing = await prisma.recipe.findUnique({ where: { slug: rest.slug } });

    if (existing) {
      // Refresh metadata + translations on the recipe row itself. Ingredients
      // are NOT recreated — their UUIDs may be referenced by meal-plan entries
      // or shopping-list items, and dropping them would cascade-delete those.
      // If you change ingredient *content* later, write a migration.
      await prisma.recipe.update({
        where: { slug: rest.slug },
        data: {
          imageUrl: rest.imageUrl,
          titleI18n: rest.titleI18n,
          descriptionI18n: rest.descriptionI18n,
        },
      });
      updated += 1;
      continue;
    }

    await prisma.recipe.create({
      data: {
        ...rest,
        source: 'official',
        isPublic: true,
        isApproved: true,
        previewOnly: false,
        ingredients: { create: ingredients },
      },
    });
    created += 1;
  }

  console.log(`✓ Seed complete — ${created} created, ${updated} updated`);
}

main()
  .catch((e) => {
    console.error(e);
    process.exit(1);
  })
  .finally(() => prisma.$disconnect());
