/**
 * Dishday seed — 18 official curated recipes with localized titles,
 * descriptions, and ingredient names in 6 non-English languages.
 *
 *   English is the canonical column; the *_i18n maps hold ru/uk/de/it/es/fr
 *   variants. Clients render via `pickLocalized(canonical, i18n, locale)`
 *   from `@dishday/utils` — falls back to canonical for any locale we
 *   don't have a translation for.
 *
 *   Idempotent — runs safely on every deploy. New recipes are inserted;
 *   existing rows (matched by slug) are updated with the latest image,
 *   translations, and metadata. Ingredients on existing rows are NOT
 *   re-created (we'd lose `id`s referenced from meal-plan entries).
 */

import { PrismaClient } from '@prisma/client';

const prisma = new PrismaClient();

// Helper: Unsplash CDN URL sized for mobile cards.
const img = (id: string) =>
  `https://images.unsplash.com/${id}?w=600&h=400&fit=crop&q=80&auto=format`;

/** BCP-47 codes we ship translations for. English is implied via canonical. */
const LOCALES = ['ru', 'uk', 'de', 'it', 'es', 'fr'] as const;
type Locale = (typeof LOCALES)[number];
type Translations = Record<Locale, string>;

interface SeedIngredient {
  name: string;
  nameI18n: Translations;
  quantity: number;
  unit: string;
  orderIndex: number;
}

interface SeedRecipe {
  title: string;
  titleI18n: Translations;
  slug: string;
  description: string;
  descriptionI18n: Translations;
  imageUrl: string;
  prepTimeMin: number;
  cookTimeMin: number;
  servings: number;
  caloriesPerServing: number;
  proteinG: number;
  carbsG: number;
  fatG: number;
  tags: string[];
  cuisine: string;
  mealType: ('breakfast' | 'lunch' | 'dinner' | 'snack')[];
  ingredients: SeedIngredient[];
}

