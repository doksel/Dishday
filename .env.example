# ─── Supabase ──────────────────────────────────────────────
# Found at: https://supabase.com/dashboard/project/<id>/settings/api
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Supabase direct Postgres connection for Prisma (Connection pooling: Session mode, port 5432)
# https://supabase.com/dashboard/project/<id>/settings/database
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?schema=public

# ─── API ───────────────────────────────────────────────────
PORT=4000
# Used to sign internal short-lived tokens (e.g. service-to-service); generate with: openssl rand -hex 32
JWT_SECRET=replace-with-64-char-random-hex

# ─── AI provider ───────────────────────────────────────────
# Priority: if ANTHROPIC_API_KEY is set → Claude. Otherwise → Gemini.
# Leave both empty to disable AI features (API still starts).

# Option A — Anthropic Claude (https://console.anthropic.com, pay-as-you-go ~$0.04/plan)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Option B — Google Gemini (https://aistudio.google.com, free tier: 1500 req/day)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ─── Stripe ────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_...

# ─── Redis (Bull queue) ────────────────────────────────────
# Local: `docker run -p 6379:6379 redis:7`
REDIS_URL=redis://localhost:6379

# ─── Next.js / Web ─────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_API_URL=http://localhost:4000/v1

# ─── Expo / Mobile ─────────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_API_URL=http://localhost:4000/v1

# ─── AI Gemini ─────────────────────────────────────────
GEMINI_MODEL=
GEMINI_API_KEY=
USE_MOCK_AI=